{
  "extends": "@repo/config/tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "types": ["worker-configuration.d.ts"],
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
